{
  "manifest_version": 3,
  "name": "SNow Glide",
  "version": "2.0.17",
  "description": "Fonctionnalités additionnelles sur le ticketing Service Now automatisant les tâches récurrentes du Service Desk. By Dylan MOULIN.",
  "content_scripts": [
    {
      "matches": ["https://aagprod.service-now.com/*"],
      "js": ["index.js"],
      "css": ["overlay/overlay.css"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["https://aagprod.service-now.com/*"],
      "js": ["template/template.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [ "overlay/overlay.html", "template/template.json" ],
      "matches": [ "https://aagprod.service-now.com/*" ]
    }
  ]
}
